{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quant Toolbox Configuration Schema",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "ticker": {
          "type": "string",
          "description": "Primary ticker for stock analysis mode."
        },
        "start_date": {
          "type": "string",
          "format": "date",
          "description": "Start date for data fetching (YYYY-MM-DD)."
        },
        "end_date": {
          "type": "string",
          "format": "date",
          "description": "End date for data fetching (YYYY-MM-DD)."
        },
        "universe": {
          "type": "string",
          "enum": ["sp500", "sp500_utilities", "sp500_utilities_staples", "etf_pairs", "etf_sector", "etf_country", "etf_commodity", "sp500_banks", "sp500_tech", "sp500_reits", "cross_listed", "cef_pimco"],
          "description": "Universe name for multi-asset builds and pairs research."
        },
        "excluded_periods": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date" },
              "end": { "type": "string", "format": "date" }
            },
            "required": ["start", "end"]
          },
          "description": "List of date ranges to exclude from analysis (e.g. COVID peak)."
        }
      },
      "required": ["start_date", "end_date"],
      "additionalProperties": false
    },
    "pairs": {
      "type": "object",
      "properties": {
        "z_window": {
          "type": "integer",
          "minimum": 10,
          "default": 60,
          "description": "Rolling window for Z-score calculation (days)."
        },
        "z_entry": {
          "type": "number",
          "minimum": 0.5,
          "default": 2.0,
          "description": "Z-score threshold for opening a position."
        },
        "z_exit": {
          "type": "number",
          "minimum": 0.0,
          "default": 0.5,
          "description": "Z-score threshold for closing a position."
        },
        "hedge_mode": {
          "type": "string",
          "enum": ["static_ols", "kalman_filter"],
          "default": "static_ols",
          "description": "Method for calculating the hedge ratio."
        },
        "coint_mode": {
          "type": "string",
          "enum": ["engle_granger", "johansen"],
          "default": "engle_granger",
          "description": "Cointegration test type."
        },
        "regime_filter": {
          "type": "boolean",
          "default": false,
          "description": "If true, sit out during high volatility regimes."
        },
        "portfolio_size": {
          "type": "integer",
          "default": 10,
          "description": "Number of pairs to include in the aggregated portfolio backtest."
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["data"],
  "additionalProperties": false
}
